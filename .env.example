# App URLs
SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Convex
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210
NEXT_PUBLIC_CONVEX_SITE_URL=http://127.0.0.1:3210

# Better Auth
BETTER_AUTH_SECRET=replace_with_a_random_32_plus_character_secret
NEXT_PUBLIC_DISABLE_GOOGLE_AUTH=false

# Encryption key for per-user OpenRouter keys
AI_KEY_ENCRYPTION_SECRET=replace_with_a_random_base64_secret

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional email provider for reset/verification flows
RESEND_API_KEY=
AUTH_FROM_EMAIL=
